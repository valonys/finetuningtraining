# ──────────────────────────────────────────────────────────────
# ValonyLabs Studio — environment variables
# ──────────────────────────────────────────────────────────────
# Copy to `.env` and fill in the values you need. Everything is optional
# except the synth provider keys (and only if you want LLM-based Q/A
# synthesis and DPO pair generation).

# ── Base model served by the inference engine ────────────────
# Default is Qwen/Qwen2.5-7B-Instruct — any HF model id works.
# The chat template is auto-resolved from the model id.
VALONY_BASE_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── HuggingFace auth (for private datasets / gated models) ───
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────
# Synth provider — used by the Data Forge to generate Q/A pairs
# (for SFT) and (chosen, rejected) pairs (for DPO / ORPO).
#
# Priority order (first match wins):
#   1. VALONY_SYNTH_PROVIDER=<explicit override>
#   2. OLLAMA_API_KEY set   → Ollama Cloud
#   3. OLLAMA_HOST set      → local Ollama daemon
#   4. OPENAI_API_KEY set   → OpenAI
#   5. VALONY_SYNTH_BASE_URL + VALONY_SYNTH_MODEL → generic OpenAI-compat
#   6. Nothing set          → rule-based fallback (low signal)
# ──────────────────────────────────────────────────────────────

# ── Recommended: Ollama Cloud + Nemotron ─────────────────────
# Ollama Cloud runs models like Llama-3.1-Nemotron-70B at a fraction of
# frontier API cost. Nemotron is especially strong for synthetic data
# generation (Q/A pairs, DPO rejections, structured outputs).
#
# Get a key: https://ollama.com → sign in → API keys
OLLAMA_API_KEY=
OLLAMA_MODEL=nemotron
# OLLAMA_HOST=https://ollama.com        # override if needed (defaults to this)

# ── Alternative: local Ollama daemon ─────────────────────────
# If you're running `ollama serve` locally, just set OLLAMA_HOST and leave
# OLLAMA_API_KEY empty — the provider will connect without auth.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# ── Alternative: OpenAI direct ────────────────────────────────
# OPENAI_API_KEY=sk-...
# VALONY_SYNTH_MODEL=gpt-4o-mini

# ── Alternative: OpenRouter (all-in-one gateway) ─────────────
# VALONY_SYNTH_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# VALONY_SYNTH_MODEL=meta-llama/llama-3.1-70b-instruct

# ── Alternative: any OpenAI-compatible endpoint ──────────────
# Point at your own vLLM / SGLang / LiteLLM gateway, Together, Groq, etc.
# VALONY_SYNTH_BASE_URL=https://api.together.xyz/v1
# VALONY_SYNTH_API_KEY=tgp_...
# VALONY_SYNTH_MODEL=meta-llama/Llama-3.1-70B-Instruct-Turbo

# ── Inference backend override (opt-in) ─────────────────────
# Forces the inference manager to use a specific backend instead of the
# hardware-profile default (vLLM on CUDA, MLX on Apple, etc.).
#
#   vllm      — CUDA Ampere+, LoRA hot-swap, FP8 KV, RadixAttention
#   sglang    — CUDA, RadixAttention, best on MoE
#   mlx       — Apple Silicon native
#   llamacpp  — GGUF on CPU / Metal / CUDA
#   hf        — pure transformers, always works
#   ollama    — local Ollama daemon OR Ollama Cloud (reuses OLLAMA_* vars
#               above). LoRA hot-swap NOT supported — domain names route
#               to different Ollama model tags instead (see README).
# VALONY_INFERENCE_BACKEND=ollama

# When using VALONY_INFERENCE_BACKEND=ollama, set VALONY_BASE_MODEL to an
# Ollama tag rather than a HuggingFace id (the backend will warn and
# best-effort map HF ids, but an explicit tag is cleaner):
# VALONY_BASE_MODEL=llama3.1
# VALONY_BASE_MODEL=nemotron                # Ollama Cloud
# VALONY_BASE_MODEL=qwen2.5:7b

# ── Studio config paths ──────────────────────────────────────
# VALONY_CONFIG_ROOT=configs/domains       # override domain config location
# VALONY_API_PORT=8000
# VALONY_UI_PORT=7860
# VALONY_API_URL=http://localhost:8000     # Gradio → FastAPI address
